          {
            "type": "command",
            "command": "\"$HOME/.local/share/verp/track.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.local/share/verp/track.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.local/share/verp/track.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.local/share/verp/track.sh\"",
            "async": true
          }
        ]
